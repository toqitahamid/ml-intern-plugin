{
  "mcpServers": {
    "ml_intern_tools": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "python", "-m", "ml_intern_mcp.server"],
      "env": {
        "HF_TOKEN": "${HF_TOKEN}",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "hf-mcp-server": {
      "transport": "http",
      "url": "https://huggingface.co/mcp?login"
    }
  }
}
