{
  "mcpServers": {
    "ml_intern_tools": {
      "type": "stdio",
      "command": "sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run-mcp.sh"],
      "env": {
        "HF_TOKEN": "${HF_TOKEN}",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "hf-mcp-server": {
      "type": "http",
      "url": "https://huggingface.co/mcp?login"
    }
  }
}
